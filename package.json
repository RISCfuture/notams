{
  "name": "notam-service",
  "version": "1.0.0",
  "description": "FAA NMS NOTAM ingestion and API service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.app.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "migrate": "node dist/scripts/migrate.js",
    "prune": "node dist/scripts/prune-notams.js",
    "lint": "yarn lint:eslint && yarn lint:oxlint",
    "lint:eslint": "yarn node scripts/lint.cjs",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:knip": "knip",
    "lint:fix": "yarn node scripts/lint.cjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -p tsconfig.app.json --noEmit"
  },
  "keywords": [
    "notam",
    "aviation",
    "faa",
    "nms"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.51.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "saxes": "^6.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "knip": "^6.11.0",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "packageManager": "yarn@4.14.1",
  "dependenciesMeta": {
    "unrs-resolver": {
      "built": false
    }
  }
}
