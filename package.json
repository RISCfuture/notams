{
  "name": "notam-service",
  "version": "1.0.0",
  "description": "FAA SWIM NOTAM ingestion and API service",
  "main": "dist/index.js",
  "scripts": {
    "build": "yarn node scripts/pnp-run.cjs typescript/bin/tsc -p tsconfig.app.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "NODE_ENV=test yarn node scripts/pnp-run.cjs jest/bin/jest --runInBand",
    "test:watch": "NODE_ENV=test yarn node scripts/pnp-run.cjs jest/bin/jest --watch",
    "test:coverage": "NODE_ENV=test yarn node scripts/pnp-run.cjs jest/bin/jest --coverage",
    "migrate": "node dist/scripts/migrate.js",
    "prune": "node dist/scripts/prune-notams.js",
    "lint": "yarn lint:eslint && yarn lint:oxlint",
    "lint:eslint": "yarn node scripts/lint.cjs",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:knip": "knip",
    "lint:fix": "yarn node scripts/lint.cjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "yarn node scripts/pnp-run.cjs typescript/bin/tsc -p tsconfig.app.json --noEmit"
  },
  "keywords": [
    "notam",
    "aviation",
    "faa",
    "swim"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.45.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.9",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "solclientjs": "^10.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/stompit": "^0.26.6",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-util": "^30.3.0",
    "jiti": "^2.6.1",
    "knip": "^6.0.5",
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "packageManager": "yarn@4.13.0",
  "dependenciesMeta": {
    "unrs-resolver": {
      "built": false
    }
  }
}
