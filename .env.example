# Node environment
NODE_ENV=development

# Server
PORT=8080

# Database
DATABASE_URL=postgresql://notams@localhost/notams_development
TEST_DATABASE_URL=postgresql://notams@localhost/notams_test

# Database Pool Configuration
DB_POOL_MAX=30
DB_POOL_IDLE_TIMEOUT=60000
DB_CONNECTION_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000

# Database Retry Configuration
DB_MAX_RETRIES=3
DB_RETRY_BACKOFF_BASE=1000

# Circuit Breaker Configuration
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000

# NMS API Configuration (FAA NOTAM Management System)
NMS_BASE_URL=https://api-staging.cgifederal-aim.com
NMS_CLIENT_ID=your_client_id_here
NMS_CLIENT_SECRET=your_client_secret_here
NMS_POLL_INTERVAL_MS=300000

# Error Tracking
SENTRY_DSN=your_sentry_dsn_here

# Logging
LOG_LEVEL=info
